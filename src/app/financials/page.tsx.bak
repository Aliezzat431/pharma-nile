'use client';

import React, { useState, useEffect, useMemo } from 'react';
import { 
  TrendingUp, BarChart, CalendarDays, Loader2, Wallet, ArrowDownRight
} from 'lucide-react';
import { motion } from 'framer-motion';
import { getFinancialStats, getMonthlyReport, FinancialStats, MonthlyReport } from '@/lib/api/financials';
import {
  AreaChart, Area, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer,
  BarChart as ReBarChart, Bar, Cell, PieChart, Pie, Legend
} from 'recharts';

const COLORS = ['#00CED1', '#D4AF37', '#FF4E4E'];

const ARABIC_MONTHS: Record<string, string> = {
  'January':   'ГҷЕ ГҷвҖ ГҳВ§ГҷЕ ГҳВұ',
  'February':  'ГҷВҒГҳВЁГҳВұГҳВ§ГҷЕ ГҳВұ',
  'March':     'ГҷвҖҰГҳВ§ГҳВұГҳВі',
  'April':     'ГҳВЈГҳВЁГҳВұГҷЕ ГҷвҖһ',
  'May':       'ГҷвҖҰГҳВ§ГҷЕ ГҷЛҶ',
  'June':      'ГҷЕ ГҷЛҶГҷвҖ ГҷЕ ГҷЛҶ',
  'July':      'ГҷЕ ГҷЛҶГҷвҖһГҷЕ ГҷЛҶ',
  'August':    'ГҳВЈГҳВәГҳВіГҳВ·ГҳВі',
  'September': 'ГҳВіГҳВЁГҳВӘГҷвҖҰГҳВЁГҳВұ',
  'October':   'ГҳВЈГҷЖ’ГҳВӘГҷЛҶГҳВЁГҳВұ',
  'November':  'ГҷвҖ ГҷЛҶГҷВҒГҷвҖҰГҳВЁГҳВұ',
  'December':  'ГҳВҜГҷЕ ГҳВіГҷвҖҰГҳВЁГҳВұ',
};

const tl = (v?: number | string | null) => {
  const num = Number(v);
  return isNaN(num) ? 'ГҷВ ' : num.toLocaleString('ar-EG');
};

const CustomTooltip = ({
  active,
  payload,
  label,
}: {
  active?: boolean;
  payload?: any[];
  label?: string;
}) => {
  if (!active || !payload?.length) return null;

  return (
    <div className="glass-card p-3 text-right min-w-[160px] bg-black/80 backdrop-blur-md border border-white/10 rounded-xl" dir="rtl">
      <p className="text-xs font-bold text-gray-400 font-cairo mb-2">{label}</p>
      {payload.map((p, i) => (
        <div key={i} className="flex items-center justify-between gap-3 text-xs font-cairo my-1">
          <span style={{ color: p.color }}>{p.name}</span>
          <span className="font-bold text-white">
            {Number(p.value || 0).toLocaleString('ar-EG')} ГҳВ¬.ГҷвҖҰ
          </span>
        </div>
      ))}
    </div>
  );
};

export default function FinancialsPage() {
  const [stats, setStats] = useState<FinancialStats | null>(null);
  const [monthlyData, setMonthlyData] = useState<MonthlyReport[]>([]);
  const [loading, setLoading] = useState(true);
  const [loadingMonthly, setLoadingMonthly] = useState(true);
  const [range, setRange] = useState(30);
  const [activeTab, setActiveTab] = useState<'daily' | 'monthly'>('daily');

  useEffect(() => { 
    fetchStats(); 
  }, [range]);

  useEffect(() => {
    fetchMonthly();
  }, []);

  const fetchStats = async () => {
    setLoading(true);
    try {
      const data = await getFinancialStats(range);
      setStats(data);
    } catch (err) {
      console.error('Error fetching financial stats:', err);
    } finally {
      setLoading(false);
    }
  };

  const fetchMonthly = async () => {
    setLoadingMonthly(true);
    try {
      const data = await getMonthlyReport(undefined, 12);
      setMonthlyData(data || []);   // ГўЕ“вҖҰ ГҷвҖЎГҳВ°ГҳВ§ ГҳВ§ГҷвҖһГҳВіГҳВ·ГҳВұ ГҷЕ ГҷЖ’ГҷВҒГҷЕ 
    } catch (err) {
      console.error('Error fetching monthly report:', err);
    } finally {
      setLoadingMonthly(false);
    }
  };

  const monthlyChartData = useMemo(() => {
    if (!monthlyData.length) return [];
    return [...monthlyData].reverse().map(m => ({
      name: ARABIC_MONTHS[m.month_name?.trim()?.split(' ')[0]] || m.month_name?.split(' ')[0] || `${m.month}/${m.year}`,
      revenue: m.total_revenue || 0,
      profit:  m.total_profit || 0,
      orders:  m.total_orders || 0,
    }));
  }, [monthlyData]);

  const currentMonth = monthlyData[0] || null;

  const averageInvoiceValue = useMemo(() => {
    if (!stats || !stats.totalTransactions || stats.totalTransactions === 0) return 0;
    return stats.totalSales / stats.totalTransactions;
  }, [stats]);

  return (
    <div className="px-4 md:px-8 w-full max-w-7xl mx-auto space-y-8 animate-in fade-in duration-500 pb-12">
      
      {}
      <header className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 className="text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400 font-cairo">
            ГҳВ§ГҷвҖһГҳВӘГҷвҖҡГҳВ§ГҳВұГҷЕ ГҳВұ <span className="nile-gradient-text text-[#00CED1]">ГҳВ§ГҷвҖһГҷвҖҰГҳВ§ГҷвҖһГҷЕ ГҳВ©</span>
          </h1>
          <p className="text-gray-400 mt-2 text-lg font-cairo">ГҳВӘГҳВӯГҷвҖһГҷЕ ГҷвҖһ ГҳВ§ГҷвҖһГҳВЈГҳВұГҳВЁГҳВ§ГҳВӯГҳЕ’ ГҳВ§ГҷвҖһГҷвҖҰГҳВЁГҷЕ ГҳВ№ГҳВ§ГҳВӘ ГҷЛҶГҳВ§ГҷвҖһГҳВӘГҳВҜГҷВҒГҷвҖҡГҳВ§ГҳВӘ ГҳВ§ГҷвҖһГҷвҖ ГҷвҖҡГҳВҜГҷЕ ГҳВ© ГўвӮ¬вҖқ ГҷвҖҰГҳВӯГҳВҜГҷвҖҳГҳВ« ГҷвҖһГҳВӯГҳВёГҷЕ ГҳВ§ГҷвҖ№.</p>
        </div>
        <div className="flex gap-3 flex-wrap">
          {}
          <div className="glass-card p-1 flex gap-1 bg-white/5 rounded-xl border border-white/10">
            <button 
              onClick={() => setActiveTab('daily')}
              className={`px-4 py-2 rounded-xl text-sm font-cairo transition-all ${activeTab === 'daily' ? 'bg-[#00CED1]/25 text-[#00CED1] font-bold' : 'text-gray-400 hover:text-white'}`}
            >
              ГҷЕ ГҷЛҶГҷвҖҰГҷЕ 
            </button>
            <button 
              onClick={() => setActiveTab('monthly')}
              className={`px-4 py-2 rounded-xl text-sm font-cairo transition-all flex items-center gap-1.5 ${activeTab === 'monthly' ? 'bg-[#D4AF37]/25 text-[#D4AF37] font-bold' : 'text-gray-400 hover:text-white'}`}
            >
              <CalendarDays className="w-3.5 h-3.5" />
              ГҳВҙГҷвҖЎГҳВұГҷЕ 
            </button>
          </div>

          {activeTab === 'daily' && (
            <select 
              value={range}
              onChange={(e) => setRange(Number(e.target.value))}
              className="glass-panel px-4 py-2 text-sm bg-transparent outline-none font-cairo border border-white/10 rounded-xl"
            >
              <option value={7} className="bg-[#050505]">ГҳВўГҳВ®ГҳВұ 7 ГҳВЈГҷЕ ГҳВ§ГҷвҖҰ</option>
              <option value={30} className="bg-[#050505]">ГҳВўГҳВ®ГҳВұ 30 ГҷЕ ГҷЛҶГҷвҖҰ</option>
              <option value={90} className="bg-[#050505]">ГҳВўГҳВ®ГҳВұ 3 ГҳВЈГҳВҙГҷвҖЎГҳВұ</option>
            </select>
          )}
        </div>
      </header>

      {}
      {currentMonth && (
        <motion.div
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          className="glass-panel p-6 relative overflow-hidden border border-white/5 rounded-2xl bg-white/5"
        >
          <div className="absolute inset-0 opacity-5" 
               style={{ background: 'radial-gradient(ellipse at top left, #00CED1, transparent 60%)' }} />
          <div className="flex flex-col md:flex-row md:items-center gap-6 relative z-10">
            <div>
              <div className="flex items-center gap-2 mb-1">
                <CalendarDays className="w-4 h-4 text-[#D4AF37]" />
                <p className="text-xs text-gray-400 font-cairo">ГҷвҖҰГҷвҖһГҳВ®ГҳВө ГҳВ§ГҷвҖһГҳВҙГҷвҖЎГҳВұ ГҳВ§ГҷвҖһГҳВӯГҳВ§ГҷвҖһГҷЕ </p>
              </div>
              <h2 className="text-2xl font-bold font-cairo text-white">
                {ARABIC_MONTHS[currentMonth.month_name?.trim()?.split(' ')[0]] || currentMonth.month_name} {currentMonth.year}
              </h2>
            </div>
            <div className="flex-1 grid grid-cols-2 md:grid-cols-4 gap-4">
              {[
                { label: 'ГҳВҘГҳВ¬ГҷвҖҰГҳВ§ГҷвҖһГҷЕ  ГҳВ§ГҷвҖһГҷвҖҰГҳВЁГҷЕ ГҳВ№ГҳВ§ГҳВӘ', value: currentMonth.total_revenue, color: '#00CED1', suffix: 'ГҳВ¬.ГҷвҖҰ' },
                { label: 'ГҳВөГҳВ§ГҷВҒГҷЕ  ГҳВ§ГҷвҖһГҳВұГҳВЁГҳВӯ',       value: currentMonth.total_profit,  color: '#D4AF37', suffix: 'ГҳВ¬.ГҷвҖҰ' },
                { label: 'ГҳВ№ГҳВҜГҳВҜ ГҳВ§ГҷвҖһГҳВ·ГҷвҖһГҳВЁГҳВ§ГҳВӘ',       value: currentMonth.total_orders,  color: '#a78bfa', suffix: '' },
                { label: 'ГҳВ§ГҷвҖһГҷвҖҰГҳВұГҳВӘГҳВ¬ГҳВ№ГҳВ§ГҳВӘ',          value: currentMonth.returns_total, color: '#f87171', suffix: 'ГҳВ¬.m' },
              ].map(m => (
                <div key={m.label} className="glass-card p-4 border border-white/5 bg-black/20 rounded-xl">
                  <p className="text-gray-500 font-cairo text-xs mb-1">{m.label}</p>
                  <p className="font-bold text-xl font-cairo" style={{ color: m.color }}>
                    {tl(m.value)}{m.suffix && ` ${m.suffix}`}
                  </p>
                </div>
              ))}
            </div>
          </div>

          {}
          <div className="mt-5 relative z-10 border-t border-white/5 pt-4">
            <p className="text-xs text-gray-500 font-cairo mb-2">ГҳВӘГҷЛҶГҳВІГҷЕ ГҳВ№ ГҳВ·ГҳВұГҷвҖҡ ГҳВ§ГҷвҖһГҳВҜГҷВҒГҳВ№ ГҷвҖЎГҳВ°ГҳВ§ ГҳВ§ГҷвҖһГҳВҙГҷвҖЎГҳВұ</p>
            <div className="flex gap-4 flex-wrap">
              {[
                { label: 'ГҷвҖ ГҷвҖҡГҳВҜГҷЕ ',   value: currentMonth.cash_revenue,   color: '#00CED1' },
                { label: 'ГҳВўГҳВ¬ГҷвҖһ',    value: currentMonth.debt_revenue,   color: '#D4AF37' },
                { label: 'ГҳВөГҳВҜГҷвҖҡГҳВ§ГҳВӘ', value: currentMonth.sadqah_revenue, color: '#f472b6' },
              ].map(p => {
                const totalRev = currentMonth.total_revenue || 0;
                const pct = totalRev > 0 ? ((p.value / totalRev) * 100).toFixed(1) : '0';
                return (
                  <div key={p.label} className="flex items-center gap-2 text-xs font-cairo">
                    <div className="w-2 h-2 rounded-full" style={{ background: p.color }} />
                    <span className="text-gray-400">{p.label}</span>
                    <span className="font-bold" style={{ color: p.color }}>{pct}%</span>
                    <span className="text-gray-600">({tl(p.value)} ГҳВ¬.ГҷвҖҰ)</span>
                  </div>
                );
              })}
            </div>
          </div>
        </motion.div>
      )}

      {}
      {activeTab === 'daily' && (
        <>
          {}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {[
              { label: 'ГҳВҘГҳВ¬ГҷвҖҰГҳВ§ГҷвҖһГҷЕ  ГҳВ§ГҷвҖһГҷвҖҰГҳВЁГҷЕ ГҳВ№ГҳВ§ГҳВӘ', value: stats?.totalSales,       icon: Wallet,       color: '#00CED1' },
              { label: 'ГҳВҘГҳВ¬ГҷвҖҰГҳВ§ГҷвҖһГҷЕ  ГҳВ§ГҷвҖһГҳВЈГҳВұГҳВЁГҳВ§ГҳВӯ',  value: stats?.totalProfit,      icon: TrendingUp,   color: '#D4AF37' },
              { label: 'ГҳВҘГҳВ¬ГҷвҖҰГҳВ§ГҷвҖһГҷЕ  ГҳВ§ГҷвҖһГҳВӘГҷЖ’ГҳВ§ГҷвҖһГҷЕ ГҷВҒ', value: stats?.totalCost,        icon: ArrowDownRight, color: '#FF4E4E' },
              { label: 'ГҷвҖҰГҳВӘГҷЛҶГҳВіГҳВ· ГҳВ§ГҷвҖһГҷВҒГҳВ§ГҳВӘГҷЛҶГҳВұГҳВ©',   value: averageInvoiceValue,     icon: BarChart,     color: '#94a3b8' }
            ].map((item, i) => (
              <motion.div
                key={item.label}
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: i * 0.08 }}
                className="glass-panel p-6 relative overflow-hidden group border border-white/5 rounded-2xl bg-white/5"
              >
                <div className="flex justify-between items-start mb-4">
                   <p className="text-gray-400 font-cairo text-sm">{item.label}</p>
                   <item.icon className="w-5 h-5 opacity-40 group-hover:scale-110 transition-transform" style={{ color: item.color }} />
                </div>
                <p className="text-3xl font-bold font-sans">
                  {loading ? '...' : Number(item.value || 0).toLocaleString()} <span className="text-xs font-normal text-gray-500">ГҳВ¬.ГҷвҖҰ</span>
                </p>
                <div className="absolute -bottom-4 -right-4 w-20 h-20 rounded-full opacity-5 blur-2xl group-hover:opacity-10 transition-opacity" style={{ backgroundColor: item.color }} />
              </motion.div>
            ))}
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {}
            <div className="lg:col-span-2 glass-panel p-8 h-[450px] border border-white/5 rounded-2xl bg-white/5">
               <h2 className="text-xl font-bold font-cairo mb-8">ГҷвҖҰГҷвҖ ГҳВӯГҷвҖ ГҷвҖ° ГҳВ§ГҷвҖһГҷвҖҰГҳВЁГҷЕ ГҳВ№ГҳВ§ГҳВӘ ГҷЛҶГҳВ§ГҷвҖһГҳВЈГҳВұГҳВЁГҳВ§ГҳВӯ ГҳВ§ГҷвҖһГҷЕ ГҷЛҶГҷвҖҰГҷЕ </h2>
               <div className="w-full h-full pb-10">
                  {loading ? (
                    <div className="flex items-center justify-center h-full"><Loader2 className="animate-spin text-[#00CED1]" /></div>
                  ) : (
                    <ResponsiveContainer width="100%" height="100%">
                      <AreaChart data={stats?.dailyRevenue || []}>
                        <defs>
                          <linearGradient id="colorRev" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="5%"  stopColor="#00CED1" stopOpacity={0.2}/>
                            <stop offset="95%" stopColor="#00CED1" stopOpacity={0}/>
                          </linearGradient>
                        </defs>
                        <CartesianGrid strokeDasharray="3 3" stroke="#ffffff05" />
                        <XAxis dataKey="date" stroke="#444" tick={{ fontSize: 10, fontFamily: 'Cairo' }} />
                        <YAxis stroke="#444" tick={{ fontSize: 10 }} />
                        <Tooltip content={<CustomTooltip />} />
                        <Area type="monotone" dataKey="revenue" name="ГҳВҘГҷЕ ГҳВұГҳВ§ГҳВҜГҳВ§ГҳВӘ" stroke="#00CED1" fillOpacity={1} fill="url(#colorRev)" strokeWidth={3} />
                        <Area type="monotone" dataKey="profit"  name="ГҳВЈГҳВұГҳВЁГҳВ§ГҳВӯ"   stroke="#D4AF37" fillOpacity={0} strokeWidth={2} strokeDasharray="5 5" />
                      </AreaChart>
                    </ResponsiveContainer>
                  )}
               </div>
            </div>

            {}
            <div className="glass-panel p-8 flex flex-col justify-between border border-white/5 rounded-2xl bg-white/5">
               <h2 className="text-xl font-bold font-cairo mb-6">ГҳВ·ГҳВұГҷвҖҡ ГҳВ§ГҷвҖһГҳВҜГҷВҒГҳВ№</h2>
               <div className="h-56">
                  {loading ? (
                    <div className="flex items-center justify-center h-full"><Loader2 className="animate-spin text-[#00CED1]" /></div>
                  ) : (
                    <ResponsiveContainer width="100%" height="100%">
                       <PieChart>
                          <Pie
                            data={stats?.paymentMethodDistribution || []}
                            innerRadius={55}
                            outerRadius={80}
                            paddingAngle={5}
                            dataKey="value"
                          >
                            {(stats?.paymentMethodDistribution || []).map((_, index) => (
                              <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                            ))}
                          </Pie>
                          <Tooltip formatter={(v: any) => [`${Number(v || 0).toLocaleString('ar-EG')} ГҳВ¬.ГҷвҖҰ`]} />
                       </PieChart>
                    </ResponsiveContainer>
                  )}
               </div>
               <div className="space-y-4 mt-4">
                  {(stats?.paymentMethodDistribution || []).map((item, i) => (
                    <div key={item.name} className="flex items-center justify-between font-cairo">
                       <div className="flex items-center gap-2">
                          <div className="w-3 h-3 rounded-full" style={{ backgroundColor: COLORS[i] }} />
                          <span className="text-gray-400 text-sm">
                            {item.name === 'Cash' ? 'ГҷвҖ ГҷвҖҡГҳВҜГҷЕ ' : item.name === 'Debt' ? 'ГҳВўГҳВ¬ГҷвҖһ' : 'ГҳВөГҳВҜГҷвҖҡГҳВ§ГҳВӘ'}
                          </span>
                       </div>
                       <span className="font-bold text-sm">{item.value.toLocaleString()} ГҳВ¬.ГҷвҖҰ</span>
                    </div>
                  ))}
               </div>
            </div>
          </div>
        </>
      )}

      {}
      {activeTab === 'monthly' && (
        <>
          {}
          <div className="glass-panel p-8 h-[420px] border border-white/5 rounded-2xl bg-white/5">
            <div className="flex items-center justify-between mb-6">
              <h2 className="text-xl font-bold font-cairo">ГҳВ§ГҷвҖһГҳВЈГҳВҜГҳВ§ГҳВЎ ГҳВ§ГҷвҖһГҳВҙГҷвҖЎГҳВұГҷЕ  ГўвӮ¬вҖқ ГҳВўГҳВ®ГҳВұ 12 ГҳВҙГҷвҖЎГҳВұ</h2>
              <p className="text-xs text-gray-500 font-cairo">ГҷвҖҰГҳВІГҳВ§ГҷвҖҰГҷвҖ ГҳВ© ГҷВҒГҷЛҶГҳВұГҷЕ ГҳВ© ГҷвҖһГҷвҖһГҷвҖҰГҷвҖһГҳВ®ГҳВөГҳВ§ГҳВӘ ГҳВ§ГҷвҖһГҷвҖҰГҳВ§ГҷвҖһГҷЕ ГҳВ©</p>
            </div>
            {loadingMonthly ? (
              <div className="flex items-center justify-center h-64"><Loader2 className="animate-spin text-[#D4AF37]" /></div>
            ) : (
              <ResponsiveContainer width="100%" height="85%">
                <ReBarChart data={monthlyChartData} margin={{ top: 5, right: 5, bottom: 20, left: 10 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#ffffff05" vertical={false} />
                  <XAxis dataKey="name" tick={{ fontSize: 11, fontFamily: 'Cairo', fill: '#666' }} axisLine={false} tickLine={false} />
                  <YAxis tick={{ fontSize: 10, fill: '#666' }} axisLine={false} tickLine={false}
                         tickFormatter={v => v >= 1000 ? `${(v/1000).toFixed(0)}k` : v} />
                  <Tooltip content={<CustomTooltip />} />
                  <Legend formatter={(v) => <span className="font-cairo text-xs text-gray-400">{v}</span>} />
                  <Bar dataKey="revenue" name="ГҳВ§ГҷвҖһГҳВҘГҷЕ ГҳВұГҳВ§ГҳВҜГҳВ§ГҳВӘ" fill="#00CED1" fillOpacity={0.9} radius={[4,4,0,0]} />
                  <Bar dataKey="profit"  name="ГҳВ§ГҷвҖһГҳВЈГҳВұГҳВЁГҳВ§ГҳВӯ"   fill="#D4AF37" fillOpacity={0.9} radius={[4,4,0,0]} />
                </ReBarChart>
              </ResponsiveContainer>
            )}
          </div>

          {}
          <div className="glass-panel p-6 border border-white/5 rounded-2xl bg-white/5">
            <h2 className="text-xl font-bold font-cairo mb-6 flex items-center gap-2">
              <CalendarDays className="w-5 h-5 text-[#D4AF37]" />
              ГҷвҖҰГҷвҖһГҳВ®ГҳВө ГҳВҙГҷвҖЎГҳВұГҷЕ  ГҳВӘГҷВҒГҳВөГҷЕ ГҷвҖһГҷЕ 
            </h2>
            {loadingMonthly ? (
              <div className="flex items-center justify-center py-12"><Loader2 className="animate-spin text-[#D4AF37]" /></div>
            ) : (
              <div className="overflow-x-auto">
                <table className="w-full text-right font-cairo text-sm border-collapse">
                  <thead className="text-xs text-gray-400 bg-white/5">
                    <tr className="border-b border-white/10">
                      <th className="px-4 py-4 rounded-tr-xl whitespace-nowrap">Ш§Щ„ШҙЩҮШұ</th>
                      <th className="px-4 py-4">Ш§Щ„ШҘЩҠШұШ§ШҜШ§ШӘ</th>
                      <th className="px-4 py-4">Ш§Щ„ШЈШұШЁШ§Шӯ</th>
                      <th className="px-4 py-4">Ш§Щ„ШӘЩғШ§Щ„ЩҠЩҒ</th>
                      <th className="px-4 py-4">Ш§Щ„Ш·Щ„ШЁШ§ШӘ</th>
                      <th className="px-4 py-4">ЩҶЩӮШҜЩҠ</th>
                      <th className="px-4 py-4">ШўШ¬Щ„</th>
                      <th className="px-4 py-4 rounded-tl-xl">Щ…ШұШӘШ¬Ш№Ш§ШӘ</th>
                    </tr>
                  </thead>
                  <tbody>
                    {monthlyData.map((m, i) => {
                      const monthLabel = ARABIC_MONTHS[m.month_name?.trim()?.split(' ')[0]] || m.month_name?.split(' ')[0];
                      const isCurrentMonth = i === 0;
                      return (
                        <motion.tr
                          key={`${m.year}-${m.month}`}
                          initial={{ opacity: 0, x: 10 }}
                          animate={{ opacity: 1, x: 0 }}
                          transition={{ delay: Math.min(i * 0.03, 0.3) }}
                          className={`border-b border-white/5 hover:bg-white/5 transition-colors ${isCurrentMonth ? 'bg-[#00CED1]/5' : ''}`}
                        >
                          <td className="px-4 py-3 font-bold text-white whitespace-nowrap">
                            {monthLabel} {m.year}
                            {isCurrentMonth && (
                              <span className="mr-2 text-[10px] px-1.5 py-0.5 rounded-full bg-[#00CED1]/20 text-[#00CED1]">Ш§Щ„ШӯШ§Щ„ЩҠ</span>
                            )}
                          </td>
                          <td className="px-4 py-3 text-[#00CED1] font-bold whitespace-nowrap">{tl(m.total_revenue)} Ш¬.Щ…</td>
                          <td className="px-4 py-3 text-green-400 font-bold whitespace-nowrap">{tl(m.total_profit)} Ш¬.Щ…</td>
                          <td className="px-4 py-3 text-red-400 whitespace-nowrap">{tl(m.total_cost)} Ш¬.Щ…</td>
                          <td className="px-4 py-3 text-gray-300 whitespace-nowrap">{m.total_orders}</td>
                          <td className="px-4 py-3 text-[#00CED1] whitespace-nowrap">{tl(m.cash_revenue)}</td>
                          <td className="px-4 py-3 text-[#D4AF37] whitespace-nowrap">{tl(m.debt_revenue)}</td>
                          <td className="px-4 py-3 text-red-400/70 whitespace-nowrap">{tl(m.returns_total)}</td>
                        </motion.tr>
                      );
                    })}
                  </tbody>
                </table>
                {monthlyData.length === 0 && (
                  <div className="text-center py-12 text-gray-500 font-cairo">
                    ГҷвҖһГҳВ§ ГҳВӘГҷЛҶГҳВ¬ГҳВҜ ГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ ГҳВҙГҷвҖЎГҳВұГҷЕ ГҳВ© ГҷвҖҰГҳВіГҳВ¬ГҷвҖһГҳВ© ГҳВӯГҳВ§ГҷвҖһГҷЕ ГҳВ§ГҷвҖ№.
                  </div>
                )}
              </div>
            )}
          </div>
        </>
      )}
    </div>
  );
}

